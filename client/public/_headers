# Cloudflare Workers Static Assets — response headers.

# Content-hashed bundles never change for a given URL → cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts (stable filenames) — long cache; rename the file to bust.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Safe defaults for every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  # HSTS is a deliberate, hard-to-reverse choice. Prefer enabling it in
  # Cloudflare (SSL/TLS → Edge Certificates → HSTS) after "Always Use HTTPS",
  # or uncomment the next line to set it from code:
  # Strict-Transport-Security: max-age=31536000
